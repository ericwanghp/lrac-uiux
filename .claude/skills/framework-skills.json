        "usage": "For frontend E2E testing",
        "autoInstall": true
      },
      {
        "name": "pdf",
        "source": "github:anthropics/skills",
        "skillName": "pdf",
        "description": "PDF reading and generation",
        "usage": "When project requires PDF documentation",
        "autoInstall": true
      },
      {
        "name": "xlsx",
        "source": "github:anthropics/skills",
        "skillName": "xlsx",
        "description": "Excel spreadsheet operations",
        "usage": "When project requires spreadsheet handling",
        "autoInstall": true
      },
      {
        "name": "docx",
        "source": "github:anthropics/skills",
        "skillName": "docx",
        "description": "Word document generation",
        "usage": "When project requires Word documentation",
        "autoInstall": true
      },
      {
        "name": "pptx",
        "source": "github:anthropics/skills",
        "skillName": "pptx",
        "description": "PowerPoint presentation creation",
        "usage": "When project requires presentations",
        "autoInstall": true
      },
      {
        "name": "mcp-builder",
        "source": "github:anthropics/skills",
        "skillName": "mcp-builder",
        "description": "MCP server development",
        "usage": "For MCP integration development",
        "autoInstall": true
      },
      {
        "name": "claude-api",
        "source": "github:anthropics/skills",
        "skillName": "claude-api",
        "description": "Claude API integration",
        "usage": "For building apps with Claude API",
        "autoInstall": true
      }
    ],
    "stitch": {
      "description": "Google Stitch skills for UI/UX design workflow (Phase 2.5)",
      "repository": "google-labs-code/stitch-skills",
      "installCommand": "npx skills add google-labs-code/stitch-skills --skill {skill-name} --global",
      "requires": ["stitch-mcp"],
      "skills": [
        {
          "name": "enhance-prompt",
          "source": "github:google-labs-code/stitch-skills",
          "skillName": "enhance-prompt",
          "description": "Transform vague UI ideas into polished, Stitch-optimized prompts",
          "usage": "Before generating any Stitch design",
          "autoInstall": true
        },
        {
          "name": "stitch-loop",
          "source": "github:google-labs-code/stitch-skills",
          "skillName": "stitch-loop",
          "description": "Generate complete multi-page websites from a single prompt with baton system",
          "usage": "For page generation with Stitch",
          "autoInstall": true
        },
        {
          "name": "design-md",
          "source": "github:google-labs-code/stitch-skills",
          "skillName": "design-md",
          "description": "Analyze Stitch projects and generate DESIGN.md files documenting design systems",
          "usage": "After initial design generation",
          "autoInstall": true
        },
        {
          "name": "react-components",
          "source": "github:google-labs-code/stitch-skills",
          "skillName": "react:components",
          "description": "Convert Stitch screens to React component systems with validation and design token consistency",
          "usage": "For React component generation from designs",
          "autoInstall": true
        },
        {
          "name": "remotion",
          "source": "github:google-labs-code/stitch-skills",
          "skillName": "remotion",
          "description": "Generate walkthrough videos from Stitch projects using Remotion with smooth transitions and zooming",
          "usage": "For creating demo videos of app screens",
          "autoInstall": true
        },
        {
          "name": "shadcn-ui",
          "source": "github:google-labs-code/stitch-skills",
          "skillName": "shadcn-ui",
          "description": "Expert guidance for integrating shadcn/ui components",
          "usage": "For component specification and integration",
          "autoInstall": true
        }
      ]
    }
  },
  "installCommand": "npx skills add anthropics/skills --skill {skill-name} --global (portable) / claude skill install {skill-name} (Claude CLI fallback)",
  "checkCommand": "ls ~/.claude/skills (portable) / claude skill list (Claude CLI)"
}
