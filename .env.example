# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Node Environment
NODE_ENV=development

# API Configuration
# Next.js API routes are built-in, no external API needed

# Security
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Database (if using external DB - not required for this project)
# DATABASE_URL=postgresql://user:password@localhost:5432/lrac

# File Storage (local by default)
# DATA_DIR=/app/data
# QA_SESSIONS_DIR=/app/.auto-coding/qa-sessions

# Logging
LOG_LEVEL=info

# Feature Flags
# NEXT_PUBLIC_ENABLE_WEBSOCKET=true
# NEXT_PUBLIC_WS_URL=ws://localhost:3003
# NEXT_PUBLIC_WS_PORT=3003
# WS_PORT=3003
# LRAC_ENABLE_TERMINAL_COMMANDS=true
# LRAC_ALLOW_UNSAFE_TERMINAL_COMMANDS=false
# ENABLE_ANALYTICS=false

# Build Configuration
# NEXT_TELEMETRY_DISABLED=1
